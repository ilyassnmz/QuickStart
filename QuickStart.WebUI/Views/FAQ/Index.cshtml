@model List<QuickStart.WebUI.Dtos.FAQs.ResultFAQDto>
@{
    ViewData["Title"] = "SSS";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Sıkça Sorulan Sorular (SSS) Yönetimi</h4>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Sıra</th>
                            <th>Soru</th>
                            <th>Cevap</th>
                            <th>Durum</th>
                            <th>Sil</th>
                            <th>Güncelle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Order</td>
                                <td>@item.Question</td>
                                <td>@(item.Answer.Length > 50 ? item.Answer.Substring(0, 50) + "..." : item.Answer)</td>
                                <td>@(item.IsActive ? "Aktif" : "Pasif")</td>
                                <td><a href="/FAQ/Delete/@item.FAQId" class="btn btn-danger">Sil</a></td>
                                <td><a href="/FAQ/Edit/@item.FAQId" class="btn btn-success">Güncelle</a></td>
                            </tr>
                        }
                    </tbody>
                </table>
                <br />
                <a href="/FAQ/Create" class="btn btn-primary">Yeni Soru Ekle</a>
            </div>
        </div>
    </div>
</div>

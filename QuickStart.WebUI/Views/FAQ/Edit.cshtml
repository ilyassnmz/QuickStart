@model QuickStart.WebUI.Dtos.FAQs.UpdateFAQDto
@{
    ViewData["Title"] = "Soru Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Sıkça Sorulan Soru Güncelle</h4>
            <form class="forms-sample" method="post">
                <input type="hidden" asp-for="FAQId" />
                <div class="form-group">
                    <label>Soru</label>
                    <input type="text" class="form-control" asp-for="Question">
                </div>
                <div class="form-group">
                    <label>Cevap</label>
                    <textarea class="form-control" asp-for="Answer" rows="6"></textarea>
                </div>
                <div class="form-group">
                    <label>Sıralama</label>
                    <input type="number" class="form-control" asp-for="Order">
                </div>
                <div class="form-group">
                    <div class="form-check">
                        <label class="form-check-label">
                            <input type="checkbox" class="form-check-input" asp-for="IsActive">
                            Aktif mi?
                        </label>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary mr-2">Güncelle</button>
                <a href="/FAQ/Index" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>

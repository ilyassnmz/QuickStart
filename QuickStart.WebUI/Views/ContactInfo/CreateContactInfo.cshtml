@model QuickStart.WebUI.Dtos.ContactInfo.CreateContactInfoDto
@{
    Layout = "~/Views/_AdminLayout/Index.cshtml";
}

<div class="container">
    <br /><br />
    <form method="post">
        <label>Adres</label>
        <input asp-for="Address" class="form-control" />
        <br />
        <label>Telefon</label>
        <input asp-for="Phone" class="form-control" />
        <br />
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
        <br />
        <label>Map</label>
        <input asp-for="MapLocation" class="form-control" />
        <br />
        <button class="btn btn-primary">Kaydet</button>
    </form>
</div>

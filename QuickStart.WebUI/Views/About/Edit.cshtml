@model QuickStart.WebUI.Dtos.Abouts.UpdateAboutDto
@{
    ViewData["Title"] = "Hakkımızda Güncelle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Hakkımızda Bilgisi Güncelle</h4>
            <form class="forms-sample" method="post">
                <input type="hidden" asp-for="AboutId" />
                <div class="form-group">
                    <label>Başlık</label>
                    <input type="text" class="form-control" asp-for="Title">
                </div>
                <div class="form-group">
                    <label>Açıklama</label>
                    <textarea class="form-control" asp-for="Description" rows="4"></textarea>
                </div>
                <div class="form-group">
                    <label>Resim 1 URL</label>
                    <input type="text" class="form-control" asp-for="ImageUrl1">
                </div>
                <div class="form-group">
                    <label>Resim 2 URL</label>
                    <input type="text" class="form-control" asp-for="ImageUrl2">
                </div>
                <div class="form-group">
                    <label>Resim 3 URL</label>
                    <input type="text" class="form-control" asp-for="ImageUrl3">
                </div>
                <button type="submit" class="btn btn-primary mr-2">Güncelle</button>
                <a href="/About/Index" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>

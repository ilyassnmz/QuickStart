@model QuickStart.WebUI.Dtos.About.UpdateAboutDto
@{
    Layout = "~/Views/_AdminLayout/Index.cshtml";
}

<div class="container">
    <br /><br />
    <form method="post">
        <input type="hidden" asp-for="AboutId" />
        <label>Başlık</label>
        <input asp-for="Title" class="form-control" />
        <br />
        <label>Açıklama</label>
        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
        <br />
        <label>Resim Url 1</label>
        <input asp-for="ImageUrl1" class="form-control" />
        <br />
        <label>Resim Url 2</label>
        <input asp-for="ImageUrl2" class="form-control" />
        <br />
        <label>Resim Url 3</label>
        <input asp-for="ImageUrl3" class="form-control" />
        <br />
        <button class="btn btn-primary">Güncelle</button>
    </form>
</div>

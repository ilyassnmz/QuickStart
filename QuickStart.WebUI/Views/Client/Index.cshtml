@model List<QuickStart.WebUI.Models.ResultClientDto>
@{
    Layout = "~/Views/_AdminLayout/Index.cshtml";
}

<div class="container">
    <br /><br />
    <table class="table table-bordered">
        <tr>
            <th>#</th>
            <th>İsim</th>
            <th>Logo</th>
            <th>Website</th>
            <th>Sıra</th>
            <th>Aktif</th>
            <th>Sil</th>
            <th>Güncelle</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ClientId</td>
                <td>@item.Name</td>
                <td>@item.LogoUrl</td>
                <td>@item.WebsiteUrl</td>
                <td>@item.Order</td>
                <td>@(item.IsActive ? "Evet" : "Hayır")</td>
                <td><a href="/Client/DeleteClient/@item.ClientId" class="btn btn-danger">Sil</a></td>
                <td><a href="/Client/UpdateClient/@item.ClientId" class="btn btn-success">Güncelle</a></td>
            </tr>
        }
    </table>
    <a href="/Client/CreateClient" class="btn btn-info">Yeni Client</a>
</div>

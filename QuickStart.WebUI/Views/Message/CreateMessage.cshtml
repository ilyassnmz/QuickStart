@model QuickStart.WebUI.Dtos.Message.CreateMessageDto
@using QuickStart.WebUI.Models
@{
    Layout = "~/Views/_AdminLayout/Index.cshtml";
    var types = ViewBag.NotificationTypes as List<ResultNotificationTypeDto> ?? new List<ResultNotificationTypeDto>();
}

<div class="container">
    <br /><br />
    <form method="post">
        <label>Ad</label>
        <input asp-for="Name" class="form-control" />
        <br />
        <label>Email</label>
        <input asp-for="Email" class="form-control" />
        <br />
        <label>Konu</label>
        <input asp-for="Subject" class="form-control" />
        <br />
        <label>İçerik</label>
        <textarea asp-for="Content" class="form-control" rows="4"></textarea>
        <br />
        <label>Tür</label>
        <select asp-for="NotificationTypeId" class="form-select">
            @foreach (var t in types)
            {
                <option value="@t.NotificationTypeId">@t.Name</option>
            }
        </select>
        <br />
        <button class="btn btn-primary">Kaydet</button>
    </form>
</div>

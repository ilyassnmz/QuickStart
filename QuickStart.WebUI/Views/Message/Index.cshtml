@model List<QuickStart.WebUI.Models.ResultMessageDto>
@{
    Layout = "~/Views/_AdminLayout/Index.cshtml";
}

<div class="container">
    <br /><br />
    <table class="table table-bordered">
        <tr>
            <th>#</th>
            <th>Ad</th>
            <th>Email</th>
            <th>Konu</th>
            <th>Tür</th>
            <th>Okundu</th>
            <th>Sil</th>
            <th>Güncelle</th>
        </tr>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MessageId</td>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Subject</td>
                <td>@item.NotificationTypeName</td>
                <td>@(item.IsRead ? "Evet" : "Hayır")</td>
                <td><a href="/Message/DeleteMessage/@item.MessageId" class="btn btn-danger">Sil</a></td>
                <td><a href="/Message/UpdateMessage/@item.MessageId" class="btn btn-success">Güncelle</a></td>
            </tr>
        }
    </table>
    <a href="/Message/CreateMessage" class="btn btn-info">Yeni Mesaj</a>
</div>

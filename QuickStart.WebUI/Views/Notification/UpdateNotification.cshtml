@model QuickStart.WebUI.Dtos.Notification.UpdateNotificationDto
@using QuickStart.WebUI.Models
@{
    Layout = "~/Views/_AdminLayout/Index.cshtml";
    var types = ViewBag.NotificationTypes as List<ResultNotificationTypeDto> ?? new List<ResultNotificationTypeDto>();
}

<div class="container">
    <br /><br />
    <form method="post">
        <input type="hidden" asp-for="NotificationId" />
        <input type="hidden" asp-for="CreatedAt" />
        <label>Başlık</label>
        <input asp-for="Title" class="form-control" />
        <br />
        <label>İçerik</label>
        <textarea asp-for="Content" class="form-control" rows="4"></textarea>
        <br />
        <label>Tür</label>
        <select asp-for="NotificationTypeId" class="form-select">
            @foreach (var t in types)
            {
                <option value="@t.NotificationTypeId">@t.Name</option>
            }
        </select>
        <br />
        <label>Okundu mu?</label>
        <input asp-for="IsRead" class="form-check-input" />
        <br /><br />
        <button class="btn btn-primary">Güncelle</button>
    </form>
</div>

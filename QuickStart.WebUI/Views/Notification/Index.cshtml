@model List<QuickStart.WebUI.Dtos.Notifications.ResultNotificationDto>
@{
    ViewData["Title"] = "Bildirimler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-lg-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Bildirimler</h4>
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Başlık</th>
                            <th>İçerik</th>
                            <th>Durum</th>
                            <th>Tür Id</th>
                            <th>Sil</th>
                            <th>Güncelle</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null)
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.NotificationId</td>
                                    <td>@item.Title</td>
                                    <td>@(item.Content != null && item.Content.Length > 30 ? item.Content.Substring(0, 30) + "..." : item.Content)</td>
                                    <td>@(item.IsRead ? "Okundu" : "Okunmadı")</td>
                                    <td>@item.NotificationTypeId</td>
                                    <td><a href="/Notification/Delete/@item.NotificationId" class="btn btn-danger">Sil</a></td>
                                    <td><a href="/Notification/Edit/@item.NotificationId" class="btn btn-success">Güncelle</a></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
                <br />
                <a href="/Notification/Create" class="btn btn-primary">Yeni Bildirim Ekle</a>
            </div>
        </div>
    </div>
</div>

@model QuickStart.WebUI.Dtos.Features.CreateFeatureDto
@{
    ViewData["Title"] = "Yeni Öne Çıkan Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="col-12 grid-margin stretch-card">
    <div class="card">
        <div class="card-body">
            <h4 class="card-title">Yeni Öne Çıkan Ekle</h4>
            <form class="forms-sample" method="post">
                <div class="form-group">
                    <label>Başlık</label>
                    <input type="text" class="form-control" asp-for="Title">
                </div>
                <div class="form-group">
                    <label>Açıklama</label>
                    <textarea class="form-control" asp-for="Description" rows="4"></textarea>
                </div>
                <div class="form-group">
                    <label>İkon Sınıfı (Örn: bi bi-star)</label>
                    <input type="text" class="form-control" asp-for="Icon">
                </div>
                <div class="form-group">
                    <div class="form-check">
                        <label class="form-check-label">
                            <input type="checkbox" class="form-check-input" asp-for="IsActive">
                            Aktif mi?
                        </label>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary mr-2">Kaydet</button>
                <a href="/Feature/Index" class="btn btn-light">İptal</a>
            </form>
        </div>
    </div>
</div>

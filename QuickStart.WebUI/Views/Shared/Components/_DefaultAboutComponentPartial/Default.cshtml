@model List<QuickStart.WebUI.Models.ResultAboutDto>

<section id="about" class="about section">
    <div class="container">
        <div class="row gy-4">
            @{
                var about = Model?.FirstOrDefault();
            }
            <div class="col-lg-6 content" data-aos="fade-up" data-aos-delay="100">
                <p class="who-we-are">Who We Are</p>
                <h3>@(about?.Title ?? "About")</h3>
                <p class="fst-italic">
                    @(about?.Description ?? "")
                </p>
            </div>

            <div class="col-lg-6 about-images" data-aos="fade-up" data-aos-delay="200">
                <div class="row gy-4">
                    <div class="col-lg-6">
                        <img src="@(about?.ImageUrl1 ?? Url.Content("~/QuickStart-1.0.0/assets/img/about-company-1.jpg"))" class="img-fluid" alt="">
                    </div>
                    <div class="col-lg-6">
                        <div class="row gy-4">
                            <div class="col-lg-12">
                                <img src="@(about?.ImageUrl2 ?? Url.Content("~/QuickStart-1.0.0/assets/img/about-company-2.jpg"))" class="img-fluid" alt="">
                            </div>
                            <div class="col-lg-12">
                                <img src="@(about?.ImageUrl3 ?? Url.Content("~/QuickStart-1.0.0/assets/img/about-company-3.jpg"))" class="img-fluid" alt="">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@model List<QuickStart.WebUI.Dtos.Services.ResultServicesDto>
<!-- Services Section -->
<section id="services" class="services section light-background">
    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>Hizmetler</h2>
        <p>Hizmetlerimizle ilgili detaylı bilgileri aşağıda bulabilirsiniz.</p>
    </div>

    <div class="container">
        <div class="row g-5">
        @if(Model != null) {
            @foreach(var item in Model) {
            <div class="col-lg-6" data-aos="fade-up" data-aos-delay="100">
                <div class="service-item item-cyan position-relative">
                    <i class="@item.iconUrl icon"></i>
                    <div>
                        <h3>@item.title</h3>
                        <p>@item.description</p>
                        <a href="#" class="read-more stretched-link">Daha Fazla Bilgi <i class="bi bi-arrow-right"></i></a>
                    </div>
                </div>
            </div>
            }
        }
        </div>
    </div>
</section>
<!-- /Services Section -->
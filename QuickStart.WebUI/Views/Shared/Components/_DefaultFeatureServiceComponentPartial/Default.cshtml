@model List<QuickStart.WebUI.Models.ResultServiceDto>

<section id="featured-services" class="featured-services section light-background">
    <div class="container">
        <div class="row gy-4">
            @foreach (var item in Model ?? new List<QuickStart.WebUI.Models.ResultServiceDto>())
            {
                <div class="col-xl-4 col-lg-6" data-aos="fade-up">
                    <div class="service-item d-flex">
                        <div class="icon flex-shrink-0"><i class="@item.IconUrl"></i></div>
                        <div>
                            <h4 class="title">@item.Title</h4>
                            <p class="description">@item.Description</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

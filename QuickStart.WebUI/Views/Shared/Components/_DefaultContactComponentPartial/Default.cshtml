@model List<QuickStart.WebUI.Dtos.ContactInfos.ResultContactInfoDto>
<!-- Contact Section -->
<section id="contact" class="contact section">
    <!-- Section Title -->
    <div class="container section-title" data-aos="fade-up">
        <h2>İletişim</h2>
        <p>Bize aşağıdaki iletişim bilgilerinden ulaşabilirsiniz.</p>
    </div>

    <div class="container" data-aos="fade-up" data-aos-delay="100">
        @if(Model != null && Model.Count > 0) {
            var contact = Model.First();
            <div class="row gy-4">
                <div class="col-lg-6">
                    <div class="info-item d-flex flex-column justify-content-center align-items-center">
                        <i class="bi bi-geo-alt"></i>
                        <h3>Adres</h3>
                        <p>@contact.Address</p>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="info-item d-flex flex-column justify-content-center align-items-center">
                        <i class="bi bi-telephone"></i>
                        <h3>Bizi Arayın</h3>
                        <p>@contact.Phone</p>
                    </div>
                </div>
                <div class="col-lg-3 col-md-6">
                    <div class="info-item d-flex flex-column justify-content-center align-items-center">
                        <i class="bi bi-envelope"></i>
                        <h3>Bize E-posta Gönderin</h3>
                        <p>@contact.Email</p>
                    </div>
                </div>
            </div>

            <!-- Google Maps ve Form -->
            <div class="row gy-4 mt-1">
                <div class="col-lg-6">
                    <iframe src="@contact.MapLocation" style="border:0; width: 100%; height: 400px;"></iframe>
                </div>
                <div class="col-lg-6">
                    <form class="php-email-form">
                        <!-- Statik deneme formu -->
                        <div class="row gy-4">
                            <div class="col-md-6">
                                <input type="text" class="form-control" placeholder="Adınız">
                            </div>
                            <div class="col-md-6">
                                <input type="email" class="form-control" placeholder="E-posta">
                            </div>
                            <div class="col-md-12">
                                <input type="text" class="form-control" placeholder="Konu">
                            </div>
                            <div class="col-md-12">
                                <textarea class="form-control" rows="6" placeholder="Mesaj"></textarea>
                            </div>
                            <div class="col-md-12 text-center">
                                <button type="submit" class="btn btn-primary">Mesaj Gönder</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }
    </div>
</section>
<!-- /Contact Section -->
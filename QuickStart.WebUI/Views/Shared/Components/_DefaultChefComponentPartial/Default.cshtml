@model List<QuickStart.WebUI.Models.ResultChefDto>

<section id="team" class="section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Chefs</h2>
        <p>Our team</p>
    </div>
    <div class="container">
        <div class="row gy-4">
            @foreach (var item in Model ?? new List<QuickStart.WebUI.Models.ResultChefDto>())
            {
                <div class="col-lg-3 col-md-6" data-aos="fade-up">
                    <div class="card border-0 shadow-sm h-100">
                        <img src="@item.ImageUrl" class="img-fluid" alt="@item.FullName">
                        <div class="card-body text-center">
                            <h5 class="card-title mb-1">@item.FullName</h5>
                            <div class="text-muted mb-2">@item.Title</div>
                            <div class="d-flex justify-content-center gap-2">
                                @if (!string.IsNullOrWhiteSpace(item.InstagramUrl))
                                {
                                    <a href="@item.InstagramUrl" target="_blank" rel="noopener noreferrer">Instagram</a>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.LinkedinUrl))
                                {
                                    <a href="@item.LinkedinUrl" target="_blank" rel="noopener noreferrer">LinkedIn</a>
                                }
                                @if (!string.IsNullOrWhiteSpace(item.TwitterUrl))
                                {
                                    <a href="@item.TwitterUrl" target="_blank" rel="noopener noreferrer">X</a>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

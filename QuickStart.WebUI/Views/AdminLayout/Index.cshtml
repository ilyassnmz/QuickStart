@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var counts = ViewBag.Counts as Dictionary<string, int> ?? new Dictionary<string, int>();
}

<div class="row">
    <div class="col-md-12 grid-margin">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Baker Yönetim Paneli - Dashboard</h4>
                <p>Sistemin genel istatistiklerini ve verilerini buradan yönetebilirsiniz.</p>
                <div class="row mt-4">

                    <!-- Sliders -->
                    <div class="col-md-3 stretch-card mb-4">
                        <div class="card card-dark-blue text-white">
                            <div class="card-body">
                                <p class="mb-4">Toplam Slider</p>
                                <p class="fs-30 mb-2">@(counts.ContainsKey("Slider") ? counts["Slider"] : 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Abouts -->
                    <div class="col-md-3 stretch-card mb-4">
                        <div class="card card-light-blue text-white">
                            <div class="card-body">
                                <p class="mb-4">Hakkımızda Bloku</p>
                                <p class="fs-30 mb-2">@(counts.ContainsKey("About") ? counts["About"] : 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Services -->
                    <div class="col-md-3 stretch-card mb-4">
                        <div class="card card-light-danger text-white">
                            <div class="card-body">
                                <p class="mb-4">Hizmetler</p>
                                <p class="fs-30 mb-2">@(counts.ContainsKey("Service") ? counts["Service"] : 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Features -->
                    <div class="col-md-3 stretch-card mb-4">
                        <div class="card text-white bg-success">
                            <div class="card-body">
                                <p class="mb-4">Öne Çıkan Özellik</p>
                                <p class="fs-30 mb-2">@(counts.ContainsKey("Feature") ? counts["Feature"] : 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Testimonials -->
                    <div class="col-md-3 stretch-card mb-4">
                        <div class="card text-white bg-warning">
                            <div class="card-body">
                                <p class="mb-4">Yorumlar</p>
                                <p class="fs-30 mb-2">@(counts.ContainsKey("Testimonial") ? counts["Testimonial"] : 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- FAQs -->
                    <div class="col-md-3 stretch-card mb-4">
                        <div class="card text-white bg-info">
                            <div class="card-body">
                                <p class="mb-4">S.S.S</p>
                                <p class="fs-30 mb-2">@(counts.ContainsKey("FAQ") ? counts["FAQ"] : 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Messages -->
                    <div class="col-md-3 stretch-card mb-4">
                        <div class="card text-white bg-primary">
                            <div class="card-body">
                                <p class="mb-4">Gelen Mesajlar</p>
                                <p class="fs-30 mb-2">@(counts.ContainsKey("Message") ? counts["Message"] : 0)</p>
                            </div>
                        </div>
                    </div>

                    <!-- Notifications -->
                    <div class="col-md-3 stretch-card mb-4">
                        <div class="card text-white bg-secondary">
                            <div class="card-body">
                                <p class="mb-4">Bildirimler</p>
                                <p class="fs-30 mb-2">@(counts.ContainsKey("Notification") ? counts["Notification"] : 0)</p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
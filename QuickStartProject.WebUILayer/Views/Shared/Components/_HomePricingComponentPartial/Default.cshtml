@model List<QuickStartProject.WebUILayer.DTOs.PricingDTOs.ResultPricingDTO>

<section id="pricing" class="pricing section">
    <div class="container section-title" data-aos="fade-up">
        <h2>Fiyatlandırma</h2>
        <p>Yazılım Ajansımızla projenizi hayata geçirin. İhtiyaçlarınıza uygun esnek planlarımızdan birini seçin: Web Tasarım, Özel Yazılım (Web, Masaüstü) ve Kapsamlı Bakım Paketleri.</p>
    </div>
    <div class="container">
        <div class="row g-4 justify-content-center">
            
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="100">
                <div class="pricing-card" style="padding: 40px; border-radius: 10px; background: #fff; box-shadow: 0 0 30px rgba(0, 0, 0, 0.1); border: 1px solid #e1e1e1; text-align: center; height: 100%;">
                    <h3 style="font-weight: 600; margin-bottom: 20px; font-size: 24px;">Başlangıç Planı</h3>
                    <div class="price" style="font-size: 36px; font-weight: 700; color: #4154f1; margin-bottom: 20px;">
                        <span class="currency">₺</span>
                        <span class="amount">15.000</span>
                    </div>
                    <p class="description" style="color: #6c757d; font-size: 14px; margin-bottom: 30px;">Kurumsal kimliğinizi dijitale taşıyacak temel web tasarım paketi.</p>
                    <ul class="features" style="list-style: none; padding: 0; text-align: left; line-height: 35px; font-size: 15px;">
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Modern ve Responsive Tasarım</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Temel SEO Optimizasyonu</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> 5 Sayfaya Kadar İçerik</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> İletişim Formu / Harita</li>
                        <li><i class="bi bi-x" style="color: #ff3c00; font-size: 20px;"></i> Gelişmiş E-Ticaret Modülü</li>
                    </ul>
                    <a href="#contact" class="btn btn-outline-primary d-block mt-4" style="border-radius: 5px; padding: 10px; border: 2px solid #4154f1; color: #4154f1; text-decoration: none;">Hemen Başlayın</a>
                </div>
            </div>
            
            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="200">
                <div class="pricing-card popular" style="padding: 40px; border-radius: 10px; background: #fff; box-shadow: 0 0 30px rgba(0, 0, 0, 0.1); border: 2px solid #4154f1; text-align: center; height: 100%; position: relative;">
                    <div class="popular-badge" style="position: absolute; top: -15px; left: 50%; transform: translateX(-50%); background: #4154f1; color: #fff; padding: 5px 20px; border-radius: 20px; font-size: 14px; font-weight: 600;">En Çok Tercih Edilen</div>
                    <h3 style="font-weight: 600; margin-bottom: 20px; font-size: 24px; margin-top: 10px;">Profesyonel E-Ticaret</h3>
                    <div class="price" style="font-size: 36px; font-weight: 700; color: #4154f1; margin-bottom: 20px;">
                        <span class="currency">₺</span>
                        <span class="amount">40.000</span>
                    </div>
                    <p class="description" style="color: #6c757d; font-size: 14px; margin-bottom: 30px;">Ürünlerinizi çevrimiçi satmak için eksiksiz e-ticaret altyapısı.</p>
                    <ul class="features" style="list-style: none; padding: 0; text-align: left; line-height: 35px; font-size: 15px;">
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Özel Front-End Arayüz</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Sınırsız Ürün ve Kategori</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Sanal POS / Ödeme Entegrasyonu</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Kargo ve Sipariş Takip</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Gelişmiş SEO Yönetimi</li>
                    </ul>
                    <a href="#contact" class="btn btn-primary d-block mt-4" style="background: #4154f1; color: #fff; border-radius: 5px; padding: 10px; text-decoration: none;">Seçimi Tamamla</a>
                </div>
            </div>

            <div class="col-lg-4" data-aos="fade-up" data-aos-delay="300">
                <div class="pricing-card" style="padding: 40px; border-radius: 10px; background: #fff; box-shadow: 0 0 30px rgba(0, 0, 0, 0.1); border: 1px solid #e1e1e1; text-align: center; height: 100%;">
                    <h3 style="font-weight: 600; margin-bottom: 20px; font-size: 24px;">Kurumsal Özel Yazılım</h3>
                    <div class="price" style="font-size: 36px; font-weight: 700; color: #4154f1; margin-bottom: 20px;">
                        <span class="currency">₺</span>
                        <span class="amount">100.000+</span>
                    </div>
                    <p class="description" style="color: #6c757d; font-size: 14px; margin-bottom: 30px;">İş süreçlerinize özel, istekleriniz üzerine sıfırdan kodlanan (Back-End ve Front-End) web/mobil uygulamaları.</p>
                    <ul class="features" style="list-style: none; padding: 0; text-align: left; line-height: 35px; font-size: 15px;">
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Tamamen Özel ve Modüler Mimari</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Özelleştirilmiş Raporlama Araçları</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> API Geliştirme (Mobil / 3. Parti için)</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> Yüksek Güvenlik Mimarisi</li>
                        <li><i class="bi bi-check" style="color: #059652; font-size: 20px;"></i> 1 Yıl Ücretsiz Teknik Destek</li>
                    </ul>
                    <a href="#contact" class="btn btn-outline-primary d-block mt-4" style="border-radius: 5px; padding: 10px; border: 2px solid #4154f1; color: #4154f1; text-decoration: none;">Teklif Alın</a>
                </div>
            </div>

        </div>
    </div>
</section>
